rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - email: string (required) - User's email
    //   - displayName: string (optional) - User's display name
    //   - role: string (required) - 'admin' or 'user'
    //
    // Collection: attendance
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the user
    //   - date: string (required) - YYYY-MM-DD
    //   - status: string (required) - 'present' or 'absent'
    //   - markedBy: string (required) - UID of the admin
    //   - timestamp: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDefaultAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "daniel.shofela01@gmail.com";
    }

    function isPrivileged() {
      return isAuthenticated() && (
        isDefaultAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superviseur'])
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        isDefaultAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isSuspended() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('suspended', false) == true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'displayName']) &&
             data.uid is string &&
             (!('email' in data) || data.email is string) &&
             data.role in ['admin', 'superviseur', 'personnel', 'stagiaire', 'ouvrier'] &&
             data.displayName is string &&
             (!('dailyRate' in data) || data.dailyRate is number) &&
             (!('suspended' in data) || data.suspended is bool) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('lastUpdatedBy' in data) || data.lastUpdatedBy is string) &&
             (!('lastUpdatedByName' in data) || data.lastUpdatedByName is string) &&
             (!('lastUpdatedAt' in data) || data.lastUpdatedAt is timestamp);
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['userId', 'date', 'status', 'markedBy', 'timestamp']) &&
             data.userId is string &&
             data.date is string &&
             data.status in ['present', 'absent'] &&
             data.markedBy is string &&
             data.timestamp is timestamp &&
             (!('markedByName' in data) || data.markedByName is string) &&
             (!('updatedBy' in data) || data.updatedBy is string) &&
             (!('updatedByName' in data) || data.updatedByName is string) &&
             (!('checkIn' in data) || data.checkIn is timestamp || data.checkIn == null) &&
             (!('checkOut' in data) || data.checkOut is timestamp || data.checkOut == null);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isDefaultAdmin() ||
        (request.auth.uid != userId && isPrivileged())
      );
      
      allow list: if isAuthenticated() && (isPrivileged() || isDefaultAdmin());
      
      allow create: if (isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                    (request.resource.data.role in ['ouvrier', 'personnel', 'stagiaire']) &&
                    (!('suspended' in request.resource.data) || request.resource.data.suspended == false)) ||
                    (isDefaultAdmin() && isValidUser(request.resource.data));
      
      allow update: if isAuthenticated() && (
                    (isOwner(userId) && !isSuspended() && request.resource.data.role == resource.data.role && 
                      request.resource.data.get('dailyRate', null) == resource.data.get('dailyRate', null) && 
                      request.resource.data.get('suspended', false) == resource.data.get('suspended', false) && 
                      isValidUser(request.resource.data)) ||
                    (request.auth.uid != userId && (isAdmin() || isDefaultAdmin()) && isValidUser(request.resource.data)) || 
                    (request.auth.uid != userId && isPrivileged() && request.resource.data.role == resource.data.role && isValidUser(request.resource.data))
                   );
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && !isSuspended() && (
        (request.auth.token.email == "daniel.shofela01@gmail.com" && request.auth.token.email_verified == true) ||
        isPrivileged() ||
        resource.data.userId == request.auth.uid
      );
      
      // Privileged users (admin/super) can create/update any attendance
      allow create: if isAuthenticated() && !isSuspended() && (
                    (isPrivileged() && isValidAttendance(request.resource.data)) ||
                    (request.resource.data.userId == request.auth.uid && isValidAttendance(request.resource.data))
                  );
      
      allow update: if isAuthenticated() && !isSuspended() && (
                    (isPrivileged() && isValidAttendance(request.resource.data)) ||
                    (resource.data.userId == request.auth.uid && isValidAttendance(request.resource.data))
                  );
      
      allow delete: if isAdmin() && !isSuspended();
    }
  }
}
