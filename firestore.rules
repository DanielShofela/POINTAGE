rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - email: string (required) - User's email
    //   - displayName: string (optional) - User's display name
    //   - role: string (required) - 'admin' or 'user'
    //
    // Collection: attendance
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the user
    //   - date: string (required) - YYYY-MM-DD
    //   - status: string (required) - 'present' or 'absent'
    //   - markedBy: string (required) - UID of the admin
    //   - timestamp: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isPrivileged() {
      return isAuthenticated() && (
        (request.auth.token.email == "daniel.shofela01@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superviseur'])
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "daniel.shofela01@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'displayName']) &&
             data.uid is string &&
             (!('email' in data) || data.email is string) &&
             data.role in ['admin', 'superviseur', 'personnel', 'stagiaire', 'ouvrier'] &&
             data.displayName is string &&
             (!('dailyRate' in data) || data.dailyRate is number);
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['userId', 'date', 'status', 'markedBy', 'timestamp']) &&
             data.userId is string &&
             data.date is string &&
             data.status in ['present', 'absent'] &&
             data.markedBy is string &&
             data.timestamp is timestamp &&
             (!('checkIn' in data) || data.checkIn is timestamp || data.checkIn == null) &&
             (!('checkOut' in data) || data.checkOut is timestamp || data.checkOut == null);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        (request.auth.token.email == "daniel.shofela01@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.uid != userId && isPrivileged())
      );
      
      // Allow unauthenticated list for manual login (should be restricted in production)
      allow list: if true;
      
      // Users can create their own profile, but only as 'personnel' role by default unless they are the default admin
      // Admins/Supervisors can create ANY user profile (for manual users)
      allow create: if (isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                    (request.resource.data.role == 'personnel' || (request.auth.token.email == "daniel.shofela01@gmail.com" && request.auth.token.email_verified == true))) ||
                    (request.auth.uid != userId && isPrivileged() && isValidUser(request.resource.data));
      
      // Only admins can update roles. Supervisors can update dailyRate. Users can update their own displayName.
      allow update: if isAuthenticated() && (
                    (isOwner(userId) && request.resource.data.role == resource.data.role && 
                      request.resource.data.dailyRate == resource.data.dailyRate && isValidUser(request.resource.data)) ||
                    (request.auth.uid != userId && isAdmin() && isValidUser(request.resource.data)) || 
                    (request.auth.uid != userId && isPrivileged() && request.resource.data.role == resource.data.role && isValidUser(request.resource.data))
                   );
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && (
        (request.auth.token.email == "daniel.shofela01@gmail.com" && request.auth.token.email_verified == true) ||
        isPrivileged() ||
        resource.data.userId == request.auth.uid
      );
      
      // Privileged users (admin/super) can create/update any attendance
      allow create: if (isPrivileged() && isValidAttendance(request.resource.data)) ||
                    (isAuthenticated() && request.resource.data.userId == request.auth.uid && 
                     isValidAttendance(request.resource.data));
      
      allow update: if (isPrivileged() && isValidAttendance(request.resource.data)) ||
                    (isAuthenticated() && resource.data.userId == request.auth.uid && 
                     isValidAttendance(request.resource.data));
      
      allow delete: if isAdmin();
    }
  }
}
